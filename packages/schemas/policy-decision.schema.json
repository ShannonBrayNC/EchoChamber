{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Policy Decision",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "decisionId": { "type": "string" },
    "createdAt": { "type": "string", "format": "date-time" },
    "decision": {
      "type": "string",
      "enum": ["APPROVE", "DENY", "APPROVE_WITH_CONDITIONS"]
    },
    "contractImpact": {
      "type": "string",
      "enum": ["SAFE", "RISKY", "BREAKING"]
    },
    "summary": { "type": "string" },
    "reasons": {
      "type": "array",
      "items": { "type": "string" }
    },
    "changes": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "symbol": { "type": "string" },
          "module": { "type": "string" },
          "severity": {
            "type": "string",
            "enum": ["SAFE", "RISKY", "BREAKING"]
          },
          "changeType": { "type": "string" },
          "details": { "type": "string" }
        },
        "required": ["symbol", "severity", "changeType"]
      }
    },
    "impactedConsumers": {
      "type": "array",
      "items": { "type": "string" }
    },
    "requiredActions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "migrationPlan": { "type": "string" },
    "rollbackNotes": { "type": "string" },
    "approvedBy": { "type": "string" }
  },
  "required": [
    "decisionId",
    "createdAt",
    "decision",
    "contractImpact",
    "summary",
    "reasons",
    "changes",
    "requiredActions"
  ]
}
