{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/ShannonBrayNC/EchoChamber/contracts/schemas/echochamber.request.schema.json",
  "title": "EchoChamberRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "contractVersion",
    "sourceTool",
    "requestType",
    "sourceLanguage",
    "targetLanguage",
    "sourceText",
    "provenance"
  ],
  "properties": {
    "contractVersion": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "sourceTool": {
      "type": "string",
      "enum": [
        "manual",
        "ets",
        "opshelm",
        "christina",
        "signalforge",
        "content-engine",
        "echoliving",
        "lantern"
      ]
    },
    "requestType": {
      "type": "string",
      "enum": [
        "translate",
        "translate_and_voice",
        "pronunciation_lesson",
        "repo_artifact_translation",
        "dialogue_translation"
      ]
    },
    "sourceLanguage": {
      "type": "string",
      "minLength": 2,
      "maxLength": 16
    },
    "targetLanguage": {
      "type": "string",
      "minLength": 2,
      "maxLength": 16
    },
    "sourceText": {
      "type": "string",
      "minLength": 1
    },
    "domain": {
      "type": "string",
      "enum": [
        "personal",
        "business",
        "operations",
        "evidence",
        "governance",
        "creative",
        "hospitality",
        "technical"
      ],
      "default": "personal"
    },
    "audience": {
      "type": "string"
    },
    "tone": {
      "type": "string"
    },
    "options": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "includePhonetics": { "type": "boolean", "default": false },
        "includeAudio": { "type": "boolean", "default": false },
        "preserveFormatting": { "type": "boolean", "default": true },
        "preserveMarkdown": { "type": "boolean", "default": true },
        "returnAlignment": { "type": "boolean", "default": false },
        "returnLiteralTranslation": { "type": "boolean", "default": false },
        "saveArtifact": { "type": "boolean", "default": true }
      }
    },
    "voice": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "type": "string", "enum": ["elevenlabs"], "default": "elevenlabs" },
        "voiceId": { "type": "string" },
        "voiceLabel": { "type": "string" },
        "modelId": { "type": "string" },
        "consentId": { "type": "string" },
        "requiresConsent": { "type": "boolean", "default": true }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["workspaceId", "artifactType", "sourceId"],
      "properties": {
        "workspaceId": { "type": "string", "minLength": 1 },
        "tenantId": { "type": "string" },
        "artifactType": { "type": "string", "minLength": 1 },
        "sourceId": { "type": "string", "minLength": 1 },
        "sourceUri": { "type": "string" },
        "correlationId": { "type": "string" },
        "requestedBy": { "type": "string" }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
